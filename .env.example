# === OLX Partner API credentials (получишь после заполнения Partner details + создания приложения) ===
OLX_CLIENT_ID=
OLX_CLIENT_SECRET=
OLX_REDIRECT_URI=http://localhost:8000/callback
OLX_SCOPES=v2 read write

# === Локальная БД истории ===
DB_PATH=olx.db

# === Предохранители автоподнятия ===
PROMO_DAILY_BUDGET_KZT=5000      # максимум трат на поднятия в сутки на аккаунт
PROMO_MIN_HOURS_BETWEEN=20       # не поднимать одно объявление чаще, чем раз в N часов

# === Пороги правил оптимизации ===
LOW_VIEWS_THRESHOLD=15           # мало просмотров за период -> кандидат на оптимизацию
ZERO_LEADS_DAYS=4                # 0 обращений за N дней -> кандидат
